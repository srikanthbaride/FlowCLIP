        "# === Cell 2b: Environment compatibility patches (PyTorch 2.x + NumPy 1.20+ + PyYAML 6+) ===\n",
        "# Consolidates all runtime compatibility fixes needed for ActionCLIP on modern Colab.\n",
        "import os, re, sys, subprocess\n",
        "\n",
        "REPO = '/content/ActionCLIP'\n",
        "\n",
        "# (1) Install missing dependency: RandAugment\n",
        "subprocess.run(['pip','install','-q','git+https://github.com/ildoonet/pytorch-randaugment.git'])\n",
        "subprocess.run(['pip','install','-q','randaugment'])\n",
        "try:\n",
        "    import RandAugment  # noqa\n",
        "except Exception:\n",
        "    try:\n",
        "        import randaugment as _ra\n",
        "        sys.modules['RandAugment'] = _ra\n",
        "    except Exception as e:\n",
        "        print('RandAugment shim failed:', e)\n",
        "\n",
        "# (2) Patch deprecated NumPy aliases (np.int / np.float / np.bool / np.long)\n",
        "#     and yaml.load(f) -> yaml.safe_load(f) across all ActionCLIP source files\n",
        "_replace = {'int':'int','float':'float','bool':'bool','long':'int'}\n",
        "for root,_,files in os.walk(REPO):\n",
        "    for fn in files:\n",
        "        if not fn.endswith('.py'): continue\n",
        "        p = os.path.join(root,fn)\n",
        "        try:\n",
        "            with open(p) as fh: s = fh.read()\n",
        "            n = re.sub(r'\\bnp\\.(int|float|bool|long)\\b',\n",
        "                      lambda m: _replace[m.group(1)], s)\n",
        "            n = re.sub(r'yaml\\.load\\(([^,)]+)\\)', r'yaml.safe_load(\\1)', n)\n",
        "            if n != s:\n",
        "                with open(p,'w') as fh: fh.write(n)\n",
        "        except Exception:\n",
        "            pass\n",
        "\n",
        "# (3) Force clip.load() to use jit=False (modern PyTorch broke the JIT path)\n",
        "p = f'{REPO}/clip/clip.py'\n",
        "if os.path.exists(p):\n",
        "    with open(p) as f: s = f.read()\n",
        "    if '_load_orig' not in s:\n",
        "        s = s.replace('def load(name: str, device:',\n",
        "                      'def _load_orig(name: str, device:', 1)\n",
        "        s += ('\\n\\ndef load(name, device=None, jit=False, **kw):\\n'\n",
        "              '    import torch as _t\\n'\n",
        "              '    if device is None: device = \"cuda\" if _t.cuda.is_available() else \"cpu\"\\n'\n",
        "              '    return _load_orig(name, device=device, jit=False)\\n')\n",
        "        with open(p,'w') as f: f.write(s)\n",
        "\n",
        "# (4) Disable wandb (no API key in Colab)\n",
        "os.environ['WANDB_MODE'] = 'disabled'\n",
        "os.environ['WANDB_DISABLED'] = 'true'\n",
        "os.environ['WANDB_SILENT'] = 'true'\n",
        "\n",
        "# Patch wandb.init in train.py and test.py to use mode='disabled'\n",
        "for f in [f'{REPO}/train.py', f'{REPO}/test.py']:\n",
        "    if not os.path.exists(f): continue\n",
        "    with open(f) as fh: s = fh.read()\n",
        "    if 'wandb.init(mode=\"disabled\"' not in s and 'wandb.init(' in s:\n",
        "        s = s.replace('wandb.init(',\n",
        "                      'wandb.init(mode=\"disabled\", anonymous=\"allow\", ', 1)\n",
        "        with open(f,'w') as fh: fh.write(s)\n",
        "\n",
        "print('Environment patches applied successfully.')"
      ],
