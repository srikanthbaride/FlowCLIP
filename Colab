        "# --- Extract HMDB-51 zip and arrange videos under VIDEO_ROOT ---\n",
        "import os, zipfile, glob, shutil\n",
        "\n",
        "HMDB_ROOT  = '/content/hmdb51'\n",
        "VIDEO_ROOT = f'{HMDB_ROOT}/videos'\n",
        "SPLIT_ROOT = f'{HMDB_ROOT}/splits'\n",
        "ZIP_PATH   = f'{HMDB_ROOT}/hf/hmdb51.zip'\n",
        "\n",
        "os.makedirs(VIDEO_ROOT, exist_ok=True)\n",
        "os.makedirs(SPLIT_ROOT, exist_ok=True)\n",
        "\n",
        "print(f'Extracting {ZIP_PATH} ...')\n",
        "with zipfile.ZipFile(ZIP_PATH, 'r') as zf:\n",
        "    zf.extractall(HMDB_ROOT + '/extracted')\n",
        "\n",
        "# Inspect structure\n",
        "print('Top-level after extraction:')\n",
        "for p in sorted(os.listdir(HMDB_ROOT + '/extracted'))[:20]:\n",
        "    print(' ', p)\n",
        "\n",
        "# Find class folders (folders that directly contain .avi files)\n",
        "class_dirs = set()\n",
        "for avi in glob.glob(HMDB_ROOT + '/extracted/**/*.avi', recursive=True):\n",
        "    class_dirs.add(os.path.dirname(avi))\n",
        "\n",
        "print(f'Found {len(class_dirs)} class folders with .avi files')\n",
        "\n",
        "# Move each class folder into VIDEO_ROOT/<class_name>/\n",
        "for cd in class_dirs:\n",
        "    cls = os.path.basename(cd)\n",
        "    dst = os.path.join(VIDEO_ROOT, cls)\n",
        "    if not os.path.exists(dst):\n",
        "        shutil.move(cd, dst)\n",
        "\n",
        "# Move any split text files into SPLIT_ROOT\n",
        "for txt in glob.glob(HMDB_ROOT + '/extracted/**/*split*.txt', recursive=True):\n",
        "    shutil.copy(txt, SPLIT_ROOT)\n",
        "\n",
        "n_classes = len([d for d in os.listdir(VIDEO_ROOT) if os.path.isdir(os.path.join(VIDEO_ROOT, d))])\n",
        "n_videos  = sum(len(glob.glob(os.path.join(VIDEO_ROOT, c, '*.avi'))) for c in os.listdir(VIDEO_ROOT))\n",
        "print(f'HMDB-51 ready: {n_classes} classes, {n_videos} videos at {VIDEO_ROOT}')\n",
        "print(f'Splits at {SPLIT_ROOT}:', os.listdir(SPLIT_ROOT)[:5])\n"
