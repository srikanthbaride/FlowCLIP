        "# --- Cell 5: Download ActionCLIP backbone checkpoint ---\n",
        "# Source: https://github.com/srikanthbaride/ActionCLIP (model-zoo)\n",
        "import os, glob, shutil\n",
        "\n",
        "REPO_URL          = 'https://github.com/srikanthbaride/ActionCLIP'\n",
        "MODEL_ZOO_URL     = 'https://github.com/srikanthbaride/ActionCLIP#model-zoo'\n",
        "GDRIVE_FOLDER_URL = 'https://drive.google.com/drive/folders/1qs5SzQIl__qo2x9h0YudpGzHhNnPGqK6'\n",
        "\n",
        "VARIANT   = 'vit-b-16-8f'   # one of: vit-b-32-8f, vit-b-16-8f, vit-b-16-16f, vit-b-16-32f\n",
        "CKPT_DIR  = '/content/checkpoints'\n",
        "BACKBONE_PATH = f'{CKPT_DIR}/ViT-B-16-8F-K400.pt'\n",
        "os.makedirs(CKPT_DIR, exist_ok=True)\n",
        "\n",
        "def _has_ckpt():\n",
        "    return bool(glob.glob(os.path.join(CKPT_DIR, '**', '*.pt'), recursive=True))\n",
        "\n",
        "if _has_ckpt():\n",
        "    print(f'Checkpoint already present in {CKPT_DIR}')\n",
        "else:\n",
        "    try:\n",
        "        import gdown\n",
        "        gdown.download_folder(url=GDRIVE_FOLDER_URL, output=CKPT_DIR,\n",
        "                              quiet=False, use_cookies=False)\n",
        "        cands = sorted(glob.glob(os.path.join(CKPT_DIR, VARIANT, '*.pt')))\n",
        "        if cands:\n",
        "            shutil.copy(cands[0], BACKBONE_PATH)\n",
        "            print(f'Copied {cands[0]} -> {BACKBONE_PATH}')\n",
        "        print('Downloaded checkpoints.')\n",
        "    except Exception as e:\n",
        "        print(f'Auto-download failed ({e}).')\n",
        "        print(f'Download manually from:\\n  {MODEL_ZOO_URL}\\nor\\n  {GDRIVE_FOLDER_URL}')\n",
        "        from google.colab import files\n",
        "        for fname, data in files.upload().items():\n",
        "            dest = os.path.join(CKPT_DIR, fname)\n",
        "            with open(dest, 'wb') as f:\n",
        "                f.write(data)\n",
        "            print(f'Saved {dest}')\n"
