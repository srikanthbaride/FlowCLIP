        "# === Train linear probe & compute accuracy: RGB-only vs RGB+Flow ===\n",
        "import numpy as np\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import accuracy_score, top_k_accuracy_score\n",
        "from sklearn.preprocessing import normalize\n",
        "\n",
        "# Load features\n",
        "train = np.load('/content/train_features.npz')\n",
        "val = np.load('/content/val_features.npz')\n",
        "\n",
        "X_train_rgb = normalize(train['rgb'])\n",
        "X_val_rgb = normalize(val['rgb'])\n",
        "X_train_flow = normalize(train['flow'])\n",
        "X_val_flow = normalize(val['flow'])\n",
        "y_train = train['labels']\n",
        "y_val = val['labels']\n",
        "\n",
        "# RGB + Flow fused (concatenation)\n",
        "X_train_fused = normalize(np.concatenate([X_train_rgb, X_train_flow], axis=1))\n",
        "X_val_fused = normalize(np.concatenate([X_val_rgb, X_val_flow], axis=1))\n",
        "\n",
        "print(f'Train: {len(y_train)}, Val: {len(y_val)}, Classes: {len(set(y_val))}')\n",
        "print(f'RGB dim: {X_train_rgb.shape[1]}, Flow dim: {X_train_flow.shape[1]}, Fused dim: {X_train_fused.shape[1]}')\n",
        "\n",
        "results = {}\n",
        "for name, X_tr, X_te in [('RGB only', X_train_rgb, X_val_rgb),\n",
        "                          ('Flow only', X_train_flow, X_val_flow),\n",
        "                          ('RGB + Flow', X_train_fused, X_val_fused)]:\n",
        "    clf = LogisticRegression(max_iter=2000, C=1.0, solver='lbfgs', multi_class='multinomial')\n",
        "    clf.fit(X_tr, y_train)\n",
        "    y_pred = clf.predict(X_te)\n",
        "    y_prob = clf.predict_proba(X_te)\n",
        "    top1 = accuracy_score(y_val, y_pred) * 100\n",
        "    top5 = top_k_accuracy_score(y_val, y_prob, k=5) * 100\n",
        "    results[name] = (top1, top5)\n",
        "    print(f'{name:15s}  top-1: {top1:.2f}%  top-5: {top5:.2f}%')\n",
        "\n",
        "print('\\n' + '='*60)\n",
        "print('HMDB-51 Results (frozen CLIP ViT-B/16 + linear probe)')\n",
        "print('='*60)\n",
        "print(f'{\"stream\":15s} {\"top-1\":>8s} {\"top-5\":>8s}')\n",
        "print('-'*35)\n",
        "for name in ['RGB only', 'Flow only', 'RGB + Flow']:\n",
        "    t1, t5 = results[name]\n",
        "    print(f'{name:15s} {t1:7.2f}% {t5:7.2f}%')\n",
        "print('='*60)"
      ],
