        "# ── Cell 6: Extract RGB frames from videos ────────────────────────────────\n",
        "# Adjust VIDEO_ROOT and FRAME_ROOT to your paths.\n",
        "\n",
        "import os, subprocess\n",
        "\n",
        "VIDEO_ROOT     = '/content/hmdb51/videos'      # HMDB-51 videos extracted above\n",
        "FRAME_ROOT  = '/content/frames'   # destination for RGB frames\n",
        "os.makedirs(FRAME_ROOT, exist_ok=True)\n",
        "\n",
        "# Iterate class folders → video files\n",
        "extracted = 0\n",
        "for cls in os.listdir(VIDEO_ROOT):\n",
        "    cls_src = os.path.join(VIDEO_ROOT, cls)\n",
        "    cls_dst = os.path.join(FRAME_ROOT, cls)\n",
        "    if not os.path.isdir(cls_src): continue\n",
        "    for vid in os.listdir(cls_src):\n",
        "        if not vid.endswith(('.avi', '.mp4', '.mov')): continue\n",
        "        vid_name = os.path.splitext(vid)[0]\n",
        "        out_dir  = os.path.join(cls_dst, vid_name)\n",
        "        os.makedirs(out_dir, exist_ok=True)\n",
        "        cmd = [\n",
        "            'ffmpeg', '-i', os.path.join(cls_src, vid),\n",
        "            '-q:v', '2', '-f', 'image2',\n",
        "            os.path.join(out_dir, 'img_%05d.jpg'),\n",
        "            '-loglevel', 'error', '-y'\n",
        "        ]\n",
        "        subprocess.run(cmd, check=False)\n",
        "        extracted += 1\n",
        "\n",
        "print(f'Extracted frames for {extracted} videos → {FRAME_ROOT}')"
      ]
