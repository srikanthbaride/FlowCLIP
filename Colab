        "# --- Compute optical flow for all HMDB-51 videos ---\n",
        "import os, sys, time\n",
        "from multiprocessing import Pool\n",
        "sys.path.insert(0, '/content/ActionCLIP')\n",
        "from datasets.flow_utils import compute_optical_flow\n",
        "\n",
        "FRAME_ROOT = '/content/frames'\n",
        "FLOW_ROOT = '/content/flow'\n",
        "\n",
        "# Build list of (video_dir, output_dir) pairs\n",
        "tasks = []\n",
        "for cls in sorted(os.listdir(FRAME_ROOT)):\n",
        "    cls_frame = os.path.join(FRAME_ROOT, cls)\n",
        "    cls_flow = os.path.join(FLOW_ROOT, cls)\n",
        "    if not os.path.isdir(cls_frame):\n",
        "        continue\n",
        "    for vid in sorted(os.listdir(cls_frame)):\n",
        "        vid_frame = os.path.join(cls_frame, vid)\n",
        "        vid_flow = os.path.join(cls_flow, vid)\n",
        "        if not os.path.isdir(vid_frame):\n",
        "            continue\n",
        "        # Skip if already computed\n",
        "        if os.path.isdir(vid_flow) and len(os.listdir(vid_flow)) > 0:\n",
        "            continue\n",
        "        tasks.append((vid_frame, vid_flow))\n",
        "\n",
        "print(f'Total videos to process: {len(tasks)}')\n",
        "t0 = time.time()\n",
        "\n",
        "def process(args):\n",
        "    compute_optical_flow(args[0], args[1])\n",
        "\n",
        "with Pool(8) as pool:\n",
        "    for i, _ in enumerate(pool.imap_unordered(process, tasks)):\n",
        "        if (i+1) % 500 == 0:\n",
        "            print(f'  Processed {i+1}/{len(tasks)} videos ({time.time()-t0:.0f}s)')\n",
        "\n",
        "elapsed = time.time() - t0\n",
        "print(f'Done! Processed {len(tasks)} videos in {elapsed:.0f}s')\n",
        "print(f'Flow files in {FLOW_ROOT}: {sum(len(os.listdir(os.path.join(FLOW_ROOT,c))) for c in os.listdir(FLOW_ROOT) if os.path.isdir(os.path.join(FLOW_ROOT,c)))}')"
