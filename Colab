        "# ── Cell 13: Zero-shot inference on a single video ────────────────────────\n",
        "# No training required — uses the pretrained K400 backbone directly.\n",
        "\n",
        "import sys, torch, cv2, numpy as np\n",
        "sys.path.insert(0, '/content/ActionCLIP')\n",
        "\n",
        "import clip\n",
        "from modules.Flow_Encoder import FlowCLIP\n",
        "from datasets.flow_utils import compute_optical_flow\n",
        "from utils.Augmentation import get_augmentation, get_flow_augmentation\n",
        "from types import SimpleNamespace\n",
        "\n",
        "DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "\n",
        "# ── load CLIP backbone\n",
        "model, preprocess = clip.load('ViT-B/16', device=DEVICE)\n",
        "model.eval()\n",
        "\n",
        "# ── wrap with FlowCLIP\n",
        "flow_encoder = FlowCLIP(model).to(DEVICE).eval()\n",
        "\n",
        "# ── label prompts\n",
        "LABELS = ['clapping', 'running', 'jumping', 'waving', 'sitting', 'walking']\n",
        "text_tokens = clip.tokenize([f'a person is {l}' for l in LABELS]).to(DEVICE)\n",
        "\n",
        "with torch.no_grad():\n",
        "    text_features = model.encode_text(text_tokens)\n",
        "    text_features = text_features / text_features.norm(dim=-1, keepdim=True)\n",
        "\n",
        "# ── read a video\n",
        "VIDEO_PATH = '/content/sample.avi'   # ← upload your video here\n",
        "\n",
        "if not os.path.exists(VIDEO_PATH):\n",
        "    print(f'Upload a video to {VIDEO_PATH} then re-run this cell.')\n",
        "else:\n",
        "    cap = cv2.VideoCapture(VIDEO_PATH)\n",
        "    frames = []\n",
        "    while True:\n",
        "        ret, f = cap.read()\n",
        "        if not ret: break\n",
        "        frames.append(cv2.cvtColor(f, cv2.COLOR_BGR2RGB))\n",
        "    cap.release()\n",
        "\n",
        "    # sample 8 frames uniformly\n",
        "    N = 8\n",
        "    idx = np.linspace(0, len(frames)-1, N, dtype=int)\n",
        "    sampled = [frames[i] for i in idx]\n",
        "\n",
        "    # preprocess + encode video frames\n",
        "    from PIL import Image\n",
        "    imgs = torch.stack([preprocess(Image.fromarray(f)) for f in sampled]).unsqueeze(0).to(DEVICE)\n",
        "    with torch.no_grad():\n",
        "        vid_feat = model.encode_image(imgs.view(-1, *imgs.shape[2:]))\n",
        "        vid_feat = vid_feat.mean(0, keepdim=True)\n",
        "        vid_feat = vid_feat / vid_feat.norm(dim=-1, keepdim=True)\n",
        "\n",
        "    sim = (vid_feat @ text_features.T).softmax(dim=-1).squeeze().cpu().numpy()\n",
        "    for label, score in sorted(zip(LABELS, sim), key=lambda x: -x[1]):\n",
        "        bar = '█' * int(score * 40)\n",
        "        print(f'  {label:15s} {score*100:5.1f}%  {bar}')"
      ]
