        "# --- Download HMDB-51 (videos + train/test splits) ---\n",
        "# The legacy URL at serre-lab.clps.brown.edu now returns an HTML redirect page,\n",
        "# so we pull the dataset from the HuggingFace mirror (jili5044/hmdb51).\n",
        "import os, glob, subprocess\n",
        "\n",
        "HMDB_ROOT  = '/content/hmdb51'\n",
        "VIDEO_ROOT = f'{HMDB_ROOT}/videos'\n",
        "SPLIT_ROOT = f'{HMDB_ROOT}/splits'\n",
        "os.makedirs(VIDEO_ROOT, exist_ok=True)\n",
        "os.makedirs(SPLIT_ROOT, exist_ok=True)\n",
        "\n",
        "# Clean any prior corrupt 5KB HTML-as-rar files from earlier attempts\n",
        "for stale in [f'{HMDB_ROOT}/hmdb51_org.rar', f'{HMDB_ROOT}/test_train_splits.rar']:\n",
        "    try:\n",
        "        if os.path.exists(stale) and os.path.getsize(stale) < 1_000_000:\n",
        "            os.remove(stale)\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "# Install tools\n",
        "subprocess.run(['pip', '-q', 'install', 'huggingface_hub'], check=False)\n",
        "subprocess.run(['apt-get', '-qq', 'install', '-y', 'unrar'], check=False)\n",
        "\n",
        "from huggingface_hub import snapshot_download\n",
        "\n",
        "# Pull the entire HF dataset repo (videos are stored as per-class .avi or archives)\n",
        "local_dir = snapshot_download(\n",
        "    repo_id='jili5044/hmdb51',\n",
        "    repo_type='dataset',\n",
        "    local_dir=HMDB_ROOT + '/hf',\n",
        "    local_dir_use_symlinks=False,\n",
        ")\n",
        "print(f'HF dataset cached at: {local_dir}')\n",
        "!ls -la {local_dir} | head -50\n"
      ]
